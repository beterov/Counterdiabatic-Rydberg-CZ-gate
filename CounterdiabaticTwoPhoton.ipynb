  {
   "cell_type": "markdown",
   "id": "ae53ae2d-6904-4f43-898b-a6ffe1d074f5",
   "metadata": {},
   "source": [
    "**Two-photon counterdiabatic gate for finite blockade strength**"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 20,
   "id": "cc78e58a-6ca8-42ff-8bbe-2275e77e92a8",
   "metadata": {},
   "outputs": [],
   "source": [
    "from rydopt.types import HamiltonianFunction\n",
    "class CZGateTwoPhotonFull:\n",
    "\n",
    "            \n",
    "    def __init__(self,  DeltaP: float, DecayP: float, DecayR: float, Vnn: float):\n",
    "        self._DeltaP = DeltaP\n",
    "        self._DecayP = DecayP\n",
    "        self._DecayR = DecayR\n",
    "        self._Vnn = Vnn\n",
    "        \n",
    "    def initial_basis_states(self) -> tuple[jnp.ndarray, ...]:\n",
    "        return jnp.array([1,0,0], dtype=complex), jnp.array([1,0,0,0,0,0], dtype=complex)\n",
    "\n",
    "    def hamiltonian_functions_for_basis_states(self) -> tuple[HamiltonianFunction, ...]:\n",
    "        def hamiltonian1(Delta: float, Xi: float, Omega: float) -> jnp.ndarray:\n",
    "            \"\"\"single-atom excitation with states 01,0e,0r\"\"\"\n",
    "            \n",
    "            DeltaP=self._DeltaP\n",
    "            DecayP=self._DecayP\n",
    "            DecayR=self._DecayR\n",
    "            \n",
    "            DeltaP=self._DeltaP\n",
    "            Vnn=self._Vnn\n",
    "            Omega1=jnp.sqrt(2*DeltaP*(Omega-1j * Xi))\n",
    "            Omega1C=jnp.sqrt(2*DeltaP*(Omega+1j* Xi))\n",
    "            \n",
    "            Omega2=jnp.sqrt(2*DeltaP*(Omega-1j * Xi))\n",
    "            Omega2C=jnp.sqrt(2*DeltaP*(Omega+1j* Xi))\n",
    "            return jnp.array(\n",
    "            [\n",
    "                   [0,Omega1*0.5,0],\n",
    "                   [Omega1C*0.5,DeltaP-1j*0.5*DecayP,Omega2*0.5],\n",
    "                   [0,Omega2C*0.5,Delta-1j*0.5*DecayR]\n",
    "                                                          \n",
    "                ]\n",
    "            )\n",
    "        def hamiltonian2(Delta: float, Xi: float, Omega: float) -> jnp.ndarray:\n",
    "            \"\"\"two-atom excitation with states 11,1e+e1,1r+r1,ee,er+re,rr\"\"\"\n",
    "           \n",
    "            DeltaP=self._DeltaP\n",
    "            DecayP=self._DecayP\n",
    "            DecayR=self._DecayR\n",
    "            Vnn=self._Vnn\n",
    "            Omega1=jnp.sqrt(2*DeltaP*(Omega-1j * Xi))\n",
    "            Omega1C=jnp.sqrt(2*DeltaP*(Omega+1j* Xi))\n",
    "            \n",
    "            Omega2=jnp.sqrt(2*DeltaP*(Omega-1j * Xi))\n",
    "            Omega2C=jnp.sqrt(2*DeltaP*(Omega+1j* Xi))\n",
    "            \n",
    "            return jnp.array([\n",
    "                   [0,Omega1*0.5*jnp.sqrt(2),0,0,0,0],   #11\n",
    "                   [Omega1C*0.5*jnp.sqrt(2),DeltaP-1j*0.5*DecayP,Omega2*0.5,Omega1*0.5*jnp.sqrt(2),0,0],  #1e+e1\n",
    "                   [0,Omega2C*0.5,Delta-1j*0.5*DecayR,0,Omega1*0.5,0], #1r+r1\n",
    "                   [0,Omega1C*0.5*jnp.sqrt(2),0,2*DeltaP-1j*DecayP,Omega2*0.5*jnp.sqrt(2),0], #ee\n",
    "                   [0,0,Omega1C*0.5,Omega2C*0.5*jnp.sqrt(2),Delta+DeltaP-1j*(DecayP+DecayR)*0.5,Omega2*0.5*jnp.sqrt(2)], #er+re\n",
    "                   [0,0,0,0,Omega2C*0.5*jnp.sqrt(2),2*Delta+Vnn-1j*DecayR] #rr\n",
    "                                                          \n",
    "            ]\n",
    "\n",
    "              \n",
    "            )\n",
    "        return hamiltonian1, hamiltonian2\n",
    "\n",
    "\n",
    "\n",
    "   \n",
    "\n",
    "    \n",
    "    def process_fidelity(\n",
    "        self, final_basis_states: tuple[jnp.ndarray, ...]\n",
    "    ) -> jnp.ndarray:\n",
    "        # Obtained diagonal gate matrix\n",
    "        obtained_gate = jnp.array(\n",
    "            [\n",
    "                1,\n",
    "                final_basis_states[0][0],\n",
    "                final_basis_states[0][0],\n",
    "                final_basis_states[1][0],\n",
    "            ]\n",
    "        )\n",
    "\n",
    "        # Targeted diagonal gate matrix\n",
    "        p = jnp.angle(obtained_gate[1]) \n",
    "        t = np.pi\n",
    "\n",
    "        targeted_gate = jnp.stack(\n",
    "            [\n",
    "                1,\n",
    "                jnp.exp(1j * p),\n",
    "                jnp.exp(1j * p),\n",
    "                jnp.exp(1j * (2 * p + t)),\n",
    "            ]\n",
    "        )\n",
    "        return jnp.abs(jnp.vdot(targeted_gate, obtained_gate)) ** 2 / len(targeted_gate) ** 2"
   ]
  },
